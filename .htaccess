RewriteEngine On

# Nếu hosting/proxy có HTTPS thì giữ nguyên request HTTPS, không đá POST sang URL khác
# Chỉ redirect URL .php sang URL sạch với GET/HEAD, KHÔNG redirect POST
RewriteCond %{REQUEST_METHOD} ^(GET|HEAD)$ [NC]
RewriteRule ^$ /trang-chu [R=301,L]

RewriteCond %{REQUEST_METHOD} ^(GET|HEAD)$ [NC]
RewriteCond %{THE_REQUEST} \s/+index(?:\.php)?(?:[?\s]|$) [NC]
RewriteRule ^index(?:\.php)?$ /trang-chu [R=301,L]

# Không redirect webhook/API quan trọng
RewriteRule ^webhooks/sepay\.php$ - [L]
RewriteRule ^callback_atm\.php$ - [L]

# Chỉ redirect .php sang URL sạch với GET/HEAD
RewriteCond %{REQUEST_METHOD} ^(GET|HEAD)$ [NC]
RewriteCond %{REQUEST_URI} !^/(assets|img|uploads|vendor|webhooks)/ [NC]
RewriteCond %{REQUEST_URI} !^/callback_atm\.php$ [NC]
RewriteCond %{THE_REQUEST} \s/+(.+?)\.php(?:[?\s]|$) [NC]
RewriteRule ^(.+?)\.php$ /$1 [R=301,L]

# Rewrite trang chủ đẹp về file thật
RewriteRule ^trang-chu/?$ index.php [L,QSA]

# Rewrite URL chi tiết sản phẩm đẹp
RewriteRule ^([^/]+)/([^/]+)\.html$ product.php?category_slug=$1&slug=$2 [L,QSA]

# Rewrite các URL không có .php sang file .php tương ứng nếu file tồn tại
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.+?)/?$ $1.php [L,QSA]
